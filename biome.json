{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 80
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"files": {
		"includes": ["src/**", "electron/**", "e2e/**", "vite.config.ts", "playwright.config.ts"],
		"experimentalScannerIgnores": ["dist", "dist-electron", "node_modules"]
	}
}
