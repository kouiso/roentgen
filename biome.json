{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 80
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"files": {
		"includes": [
			"src/**",
			"electron/**",
			"e2e/**",
			"vite.config.ts",
			"playwright.config.ts",
			"!!**/dist",
			"!!**/dist-electron",
			"!!**/node_modules"
		]
	}
}
